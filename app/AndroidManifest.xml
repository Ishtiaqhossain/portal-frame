<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="1"
    android:versionName="1.0">


    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="Portal Frame"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false">

        <!-- Foreground / kiosk slideshow. Not a LAUNCHER entry: Portal's launcher
             would then show a second icon, and the slideshow is reached via the
             screensaver (FrameDreamService) or a long-press on it. Started via
             the dream, the "Photos" setup screen, or `am start` for testing. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Frame"
            android:excludeFromRecents="true"
            android:screenOrientation="landscape" />

        <!-- The real screensaver path: a standard Android DreamService that
             Portal's Daydream framework can be pointed at. -->
        <service
            android:name=".FrameDreamService"
            android:exported="true"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

        <!-- The "Photos" app icon: the Compose settings/setup screen (Milestone 3). -->
        <activity
            android:name=".SettingsActivity"
            android:exported="true"
            android:label="Photos"
            android:icon="@mipmap/ic_launcher"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Camera QR scanner + manual entry (still view-based; SettingsActivity
             hands off here with a "goto" extra). Ported to Compose in a later step. -->
        <activity
            android:name=".PhotosActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:screenOrientation="landscape" />

        <!-- Compose slideshow (migration Milestone 4) — develop/verify alongside the
             Java MainActivity screensaver; becomes the dream target once at parity. -->
        <activity
            android:name=".SlideshowComposeActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:screenOrientation="landscape" />

        <!-- Set the Google Photos shared-album URL over ADB (see ConfigReceiver). -->
        <receiver
            android:name=".ConfigReceiver"
            android:exported="true" />

    </application>
</manifest>
