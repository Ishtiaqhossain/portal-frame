<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Slideshow window theme. windowDisablePreview stops the framework from showing
      a starting window on (re)launch — otherwise a warm start / the dream re-entry
      flashes the cached TASK SNAPSHOT (the previous run's photo) for ~1s before the
      new first frame draws. windowBackground is solid black so any pre-draw gap is
      black, not a stale image.
    -->
    <style name="Theme.Frame" parent="@android:style/Theme.Black.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowDisablePreview">true</item>
    </style>
</resources>
